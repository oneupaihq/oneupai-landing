# Environment Configuration
NODE_ENV=production

# Anthropic Configuration (for Claude)
# Model Selection (claude-3-haiku-20240307 for cost optimization, claude-3-5-haiku-20241022 for better quality)
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Chatbot Optimization Settings (Optimized for cost and performance)
CHAT_MAX_TOKENS=200
CHAT_TEMPERATURE=0.2
CHAT_RATE_LIMIT_REQUESTS=15
CHAT_RATE_LIMIT_WINDOW=60000
CHAT_CACHE_DURATION=600000

# Database (if using)
DATABASE_URL=your_database_url_here

# Authentication (if using)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-domain.com

# External APIs
FIGMA_ACCESS_TOKEN=your_figma_token_here

# Analytics (optional)
GOOGLE_ANALYTICS_ID=your_ga_id_here

# Email Service Configuration (Optional - Google Calendar sends invites automatically)
# Only needed if you want to send additional custom confirmation emails
# Generate Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password-no-spaces
CONTACT_EMAIL=your-contact-email@gmail.com

# Google Calendar OAuth Integration (Recommended)
# See OAUTH_CALENDAR_SETUP.md for complete step-by-step setup
# This method allows Google Meet links and automatic calendar invites
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=1//your-refresh-token-here
GOOGLE_CALENDAR_ID=your-email@gmail.com

# Google Calendar Iframe Integration (Alternative - simpler but less customizable)
# No API keys or complex setup required!
# Just use the Google Calendar booking page URL directly in the component
# Note: Current implementation uses custom UI with service account (see above)


# Legacy SMTP (kept for compatibility)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-character-app-password

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CACHE_COMPONENTS=true
ENABLE_CHAT_CACHING=true
ENABLE_CHAT_RATE_LIMITING=true